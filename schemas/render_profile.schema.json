{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-idea-director.dev/schemas/render_profile.schema.json",
  "title": "render_profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "goal",
    "audience",
    "visual_mode",
    "style",
    "fidelity",
    "density",
    "palette",
    "output_controls",
    "voiceover"
  ],
  "properties": {
    "profile_id": { "type": "string", "minLength": 1 },
    "profile_name": { "type": "string" },
    "goal": {
      "type": "string",
      "enum": ["teach", "persuade", "summarize", "pitch"]
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "persona", "taste_bar"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "expert"]
        },
        "persona": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "domain_context": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "taste_bar": {
          "type": "string",
          "enum": ["standard", "high", "very_high"]
        },
        "must_include": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 3 }
        },
        "must_avoid": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "visual_mode": {
      "type": "string",
      "enum": ["diagram", "illustration", "hybrid"]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "storyboard_grid",
        "technical_infographic",
        "process_diagram",
        "comparison_one_pager",
        "slide_thumbnail"
      ]
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["descriptors"],
      "properties": {
        "descriptors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 2, "maxLength": 30 }
        },
        "reference_hint": { "type": "string" },
        "forbidden_styles": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        }
      }
    },
    "fidelity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "density": {
      "type": "string",
      "enum": ["simple", "standard", "detailed"]
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "enum": ["brand", "custom"]
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["primary", "secondary", "accent", "background"]
          }
        }
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["auto", "brand", "custom"]
        },
        "primary": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" },
        "secondary": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" },
        "accent": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" },
        "background": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" }
      }
    },
    "output_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_count", "target_duration_sec", "aspect_ratio"],
      "properties": {
        "scene_count": { "type": "integer", "minimum": 3, "maximum": 8 },
        "target_duration_sec": { "type": "integer", "minimum": 30, "maximum": 300 },
        "aspect_ratio": {
          "type": "string",
          "enum": ["16:9", "9:16", "1:1", "4:5"]
        }
      }
    },
    "voiceover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "voice_style", "pace_wpm"],
      "properties": {
        "enabled": { "type": "boolean" },
        "voice_style": { "type": "string", "minLength": 2 },
        "pace_wpm": { "type": "integer", "minimum": 90, "maximum": 190 }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "high_contrast": { "type": "boolean" },
        "max_on_screen_words": { "type": "integer", "minimum": 4, "maximum": 30 }
      }
    }
  }
}
